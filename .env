# App
APP_NAME=WTV
APP_ENV=development

# Email
SUPPORT_EMAIL=support@wtv.com

# Links
VERIFY_EMAIL_URL=http://localhost:8000/verifyemail
RESET_PASSWORD_URL=http://localhost:8000/reset-password
VERIFY_EMAIL_EXPIRE_MINUTES=1440
RESET_PASSWORD_EXPIRE_MINUTES=60

# DB
DATABASE_URL=sqlite+aiosqlite:///:memory:

# Cache
REDIS_URL=redis://localhost:6379
SESSION_KEY_PREFIX=session:
USER_SESSIONS_KEY_PREFIX=user_sessions:

# Auth Token
AUTH_TOKEN_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200
ROTATE_THRESHOLD_MINUTES=4320

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_EMAIL=your-email@gmail.com
